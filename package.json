{
	"name": "the-console",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"engines": {
		"node": "^20.19.0 || >=22.12.0"
	},
	"scripts": {
		"dev": "vite",
		"makemigrations": "drizzle-kit generate --config server/utils/drizzle/drizzle.config.ts",
		"migrate": "drizzle-kit migrate --config server/utils/drizzle/drizzle.config.ts",
		"migrate:prod": "NODE_ENV=production dotenv -- drizzle-kit migrate --config server/utils/drizzle/drizzle.config.ts",
		"build": "run-p type-check \"build-only {@}\" --",
		"preview": "pnpm run build && wrangler dev",
		"build-only": "vite build",
		"type-check": "vue-tsc --build",
		"deploy": "pnpm run build && wrangler deploy",
		"cf-typegen": "wrangler types"
	},
	"dependencies": {
		"@libsql/client": "^0.15.15",
		"dotenv": "^17.2.3",
		"drizzle-orm": "^0.45.1",
		"jsonwebtoken": "^9.0.3",
		"vue": "^3.5.25",
		"vue-router": "^4.6.3"
	},
	"devDependencies": {
		"@cloudflare/vite-plugin": "^1.19.0",
		"@tsconfig/node24": "^24.0.3",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/node": "^24.10.1",
		"@vitejs/plugin-vue": "^6.0.2",
		"@vue/tsconfig": "^0.8.1",
		"dotenv-cli": "^11.0.0",
		"drizzle-kit": "^0.31.8",
		"npm-run-all2": "^8.0.4",
		"typescript": "~5.9.0",
		"vite": "^7.2.4",
		"vite-plugin-vue-devtools": "^8.0.5",
		"vue-tsc": "^3.1.5",
		"wrangler": "^4.56.0"
	}
}