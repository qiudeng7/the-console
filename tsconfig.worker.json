{
  "extends": "./tsconfig.node.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.worker.tsbuildinfo",
    "types": [
      "./worker-configuration.d.ts",
      "vite/client",
      "node"
    ],
    "paths": {
      "#server/*": [
        "./server/*"
      ],
      "#drizzle-client": [
        "./server/utils/drizzle/client"
      ]
    }
  },
  "include": [
    "server"
  ],
}